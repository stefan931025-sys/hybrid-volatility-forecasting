name: Quantamental Pipeline Automation

on:
  push:
    branches:
      - main
  schedule:
    # Triggers automatically at 05:00 UTC (07:00 AM SAST) every single morning
    - cron: '0 5 * * *'

jobs:
  run-pipeline:
    runs-on: ubuntu-latest

    steps:
    - name: Checkout Code Repository
      uses: actions/checkout@v3
      with:
        fetch-depth: 0

    - name: Configure Cloud Python Environment
      uses: actions/setup-python@v4
      with:
        python-version: '3.10'
        cache: 'pip'

    - name: Install Quant & Core Dependencies
      run: |
        python -m pip install --upgrade pip
        pip install numpy pandas scikit-learn tensorflow arch requests GitPython

    - name: Execute Analytical Model & LinkedIn Engine
      env:
        LINKEDIN_OAUTH_TOKEN: ${{ secrets.LINKEDIN_OAUTH_TOKEN }}
        LINKEDIN_PERSON_URN: ${{ secrets.LINKEDIN_PERSON_URN }}
      run: |
        python master_pipeline.py
